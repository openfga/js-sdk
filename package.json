    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "30.3.0",
    "nock": "^14.0.14",
    "ts-jest": "29.4.9",
    "typescript": "^6.0.3"
